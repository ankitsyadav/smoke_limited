<%- include('layout') %>

<!-- Floating Smoke Particles -->
<div class="smoke-particles">
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
</div>

<div class="page-content">
<h5 class="text-center mb-3 fade-in" style="color:var(--olive-light);"><i class="bi bi-heart-pulse"></i> Health Data</h5>

<% if (existing) { %>
<div class="glass-card mb-3 fade-in">
  <h6 class="card-title text-center">Today's Entry Saved</h6>
  <div class="d-flex justify-content-between text-center">
    <div><div class="health-val"><%= existing.hrv %></div><small>HRV</small></div>
    <div><div class="health-val"><%= existing.restingHR %></div><small>RHR</small></div>
    <div><div class="health-val"><%= existing.sleepScore %></div><small>Sleep</small></div>
    <div><div class="health-val"><%= existing.spo2 %>%</div><small>SpO2</small></div>
  </div>
  <!-- Refresh AI Insight button -->
  <div class="text-center mt-3">
    <button class="btn btn-sm btn-outline-light" id="refreshHealthAI" onclick="loadHealthAI()" style="border-radius:12px;font-size:0.8rem;padding:6px 16px;border-color:rgba(138,180,248,0.3);color:#8ab4f8;background:rgba(138,180,248,0.08);">
      <i class="bi bi-robot"></i> Get AI Analysis
    </button>
  </div>
  <div id="healthAILoader" style="display:none;" class="ai-loader-wrap">
    <div class="spinner-border spinner-border-sm"></div>
    <small>Analyzing health data...</small>
  </div>
  <div id="healthAIResult" style="display:none;" class="health-ai-result">
    <div class="d-flex align-items-center gap-2 mb-2">
      <span class="ai-badge"><i class="bi bi-stars"></i> GPT-4.1</span>
      <small style="color:rgba(138,180,248,0.6);font-size:0.7rem;">Health + Smoking Insight</small>
    </div>
    <div class="ai-text" id="healthAIText"></div>
  </div>
  <p class="text-center mt-2 mb-0" style="color:var(--text-muted);font-size:0.8rem;">You can update it by submitting again.</p>
</div>
<% } %>

<form action="/health" method="POST" class="fade-in">
  <div class="glass-card mb-3">
    <div class="mb-3">
      <label class="form-label">HRV (Heart Rate Variability)</label>
      <input type="number" name="hrv" class="form-control input-dark" placeholder="e.g. 45" value="<%= existing ? existing.hrv : '' %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Resting Heart Rate</label>
      <input type="number" name="restingHR" class="form-control input-dark" placeholder="e.g. 72" value="<%= existing ? existing.restingHR : '' %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Sleep Score (0-100)</label>
      <input type="number" name="sleepScore" class="form-control input-dark" placeholder="e.g. 78" min="0" max="100" value="<%= existing ? existing.sleepScore : '' %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">SpO2 (%)</label>
      <input type="number" name="spo2" class="form-control input-dark" placeholder="e.g. 97" min="80" max="100" value="<%= existing ? existing.spo2 : '' %>" required>
    </div>
    <button type="submit" class="btn btn-olive btn-ripple w-100"><i class="bi bi-check-lg"></i> Save & Analyze</button>
  </div>
</form>

</div><!-- /page-content -->

<%- include('partials/footer') %>
