<%- include('layout') %>

<!-- Floating Smoke Particles -->
<div class="smoke-particles">
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
</div>

<div class="page-content">

<!-- Risk Badge with Explanation -->
<div class="text-center mb-3 fade-in">
  <div class="risk-orb risk-<%= risk.riskLevel.toLowerCase() %>">
    <span class="risk-score"><%= risk.score %></span>
    <span class="risk-label"><%= risk.riskLevel %></span>
  </div>
  <div class="risk-explain">
    <small style="font-size:0.7rem;color:var(--text-muted);">Relapse Risk Score</small>
    <!-- Always-visible 0→100 scale bar -->
    <div class="risk-bar-wrap" style="margin-top:6px;">
      <div class="risk-bar-fill" style="width:<%= risk.score %>%;"></div>
    </div>
    <div class="risk-explain-row">
      <span class="re-safe">0 🟢 Safe</span>
      <span class="re-mid">50</span>
      <span class="re-danger">Danger 🔴 100</span>
    </div>
    <div style="font-size:0.65rem;color:var(--text-muted);margin-top:4px;">Jitna kam score, utna better 👍</div>
  </div>

  <!-- Score Breakdown Mini Bar + Accordion -->
  <% if (risk.scoreBreakdown) { %>
  <div class="score-breakdown-wrap">
    <div class="score-breakdown-bar">
      <% const sb = risk.scoreBreakdown; %>
      <% if (sb.limit > 0) { %><div class="sb-seg sb-limit" style="width:<%= sb.limit %>%"></div><% } %>
      <% if (sb.gap > 0) { %><div class="sb-seg sb-gap" style="width:<%= sb.gap %>%"></div><% } %>
      <% if (sb.trend > 0) { %><div class="sb-seg sb-trend" style="width:<%= sb.trend %>%"></div><% } %>
      <% if (sb.peak > 0) { %><div class="sb-seg sb-peak" style="width:<%= sb.peak %>%"></div><% } %>
      <% if (sb.behavior > 0) { %><div class="sb-seg sb-behavior" style="width:<%= sb.behavior %>%"></div><% } %>
    </div>
    <button id="breakdownToggle" onclick="toggleBreakdown()" style="background:none;border:none;color:var(--text-muted);font-size:0.65rem;margin-top:4px;cursor:pointer;padding:0;">▾ Score ka breakdown dekho</button>
    <div id="breakdownDetail" style="display:none;text-align:left;margin-top:6px;">
      <% if (sb.limit > 0) { %>
      <div class="bd-row"><span class="sb-dot sb-limit"></span><div><div class="bd-label">🎯 Limit — <strong><%= sb.limit %></strong>/30</div><div class="bd-desc">Aaj kitni cigarettes pi vs apna target</div></div></div>
      <% } %>
      <% if (sb.gap > 0) { %>
      <div class="bd-row"><span class="sb-dot sb-gap"></span><div><div class="bd-label">⏱️ Cigarettes ka gap — <strong><%= sb.gap %></strong>/20</div><div class="bd-desc">Cigarettes ke beech ka time kitna chhota tha</div></div></div>
      <% } %>
      <% if (sb.trend > 0) { %>
      <div class="bd-row"><span class="sb-dot sb-trend"></span><div><div class="bd-label">📈 Pichle dino ka pattern — <strong><%= sb.trend %></strong>/20</div><div class="bd-desc">Last week se smoking badh rahi hai ya kam</div></div></div>
      <% } %>
      <% if (sb.peak > 0) { %>
      <div class="bd-row"><span class="sb-dot sb-peak"></span><div><div class="bd-label">🕐 Peak time — <strong><%= sb.peak %></strong>/15</div><div class="bd-desc">Abhi tera sabse heavy smoking time kitna paas hai</div></div></div>
      <% } %>
      <% if (sb.behavior > 0) { %>
      <div class="bd-row"><span class="sb-dot sb-behavior"></span><div><div class="bd-label">⚡ Aaj ka behaviour — <strong><%= sb.behavior %></strong>/15</div><div class="bd-desc">Chain smoking ya baar baar same trigger se pee raha</div></div></div>
      <% } %>
    </div>
  </div>
  <% } %>
</div>

<!-- ═══ TOP: Today Count / Target / % vs Yesterday ═══ -->
<div class="row g-2 mb-3">
  <div class="col-4 fade-in">
    <div class="stat-card mini-stat">
      <div class="mini-val" style="font-size:1.6rem;">
        <% if (todayCount < settings.dailyGoal) { %>
          <span style="color:var(--accent-green);" id="limitIcon">✓</span>
        <% } else if (todayCount === settings.dailyGoal) { %>
          <span style="color:var(--accent-yellow);" id="limitIcon">⚠</span>
        <% } else { %>
          <span style="color:var(--accent-red);" id="limitIcon">✗</span>
        <% } %>
        <span id="todayCountDisplay"><%= todayCount %></span>
      </div>
      <div class="mini-lbl">🔢 Today</div>
    </div>
  </div>
  <div class="col-4 fade-in">
    <div class="stat-card mini-stat">
      <div class="mini-val" style="font-size:1.6rem;">
        <span id="todayLimitDisplay"><%= settings.dailyGoal %></span>
      </div>
      <div class="mini-lbl">🎯 Target</div>
    </div>
  </div>
  <div class="col-4 fade-in">
    <div class="stat-card mini-stat">
      <% 
        const ydayCount = streak.yesterdayCount || 0;
        const vsYday = ydayCount > 0 ? Math.round(((todayCount - ydayCount) / ydayCount) * 100) : 0;
      %>
      <div class="mini-val" style="font-size:1.3rem;color:<%= vsYday < 0 ? 'var(--accent-green)' : vsYday > 0 ? 'var(--accent-red)' : 'var(--accent-yellow)' %>;">
        <%= vsYday > 0 ? '+' : '' %><%= vsYday %>%
      </div>
      <div class="mini-lbl">📉 vs Yesterday</div>
    </div>
  </div>
</div>

<!-- Health Recovery Timer -->
<div class="glass-card mb-3 fade-in health-timer-card" style="padding:12px 16px;">
  <div class="text-center">
    <div style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Your body is healing</div>
    <div id="healthTimerDisplay" style="font-size:1.5rem;font-weight:700;color:var(--olive-light);">
      <% if (streak.lastMinutesAgo !== null) { %>
        <% const hh = Math.floor(streak.lastMinutesAgo / 60); const mm = streak.lastMinutesAgo % 60; %>
        <i class="bi bi-heart-pulse" style="font-size:1.1rem;"></i>
        <%= hh > 0 ? hh + 'h ' : '' %><%= mm %>m smoke-free
      <% } else { %>
        <i class="bi bi-heart-pulse"></i> Start your journey
      <% } %>
    </div>
  </div>
  <div class="health-milestones" id="healthMilestones">
    <%
      const milestones = [
        { min: 20, label: 'Heart rate normal', icon: '❤️', desc: '20 min' },
        { min: 120, label: 'Nicotine leaving blood', icon: '🩸', desc: '2 hrs' },
        { min: 480, label: 'Oxygen levels normal', icon: '🫁', desc: '8 hrs' },
        { min: 1440, label: 'Heart attack risk ↓', icon: '💪', desc: '24 hrs' },
        { min: 2880, label: 'Taste & smell return', icon: '👃', desc: '48 hrs' }
      ];
      const gapMin = streak.lastMinutesAgo || 0;
    %>
    <% milestones.forEach(function(m) { %>
      <div class="health-ms <%= gapMin >= m.min ? 'health-ms-done' : 'health-ms-locked' %>" data-min="<%= m.min %>">
        <span class="health-ms-icon"><%= m.icon %></span>
        <span class="health-ms-text"><%= m.desc %></span>
      </div>
    <% }); %>
  </div>
</div>

<!-- ⚡ Craving Prediction -->
<% if (nextCraving && nextCraving.nextLikelyHour !== null) { %>
<div class="glass-card mb-3 fade-in" style="padding:10px 14px;">
  <div class="d-flex align-items-center gap-2">
    <span style="font-size:1.3rem;">⚡</span>
    <div style="flex:1;">
      <div style="font-size:0.75rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">Next craving likely</div>
      <div style="font-size:1rem;font-weight:700;color:var(--olive-light);">
        <% const nH = nextCraving.nextLikelyHour % 12 || 12; const nS = nextCraving.nextLikelyHour >= 12 ? 'PM' : 'AM'; %>
        ~<%= nH %><%= nS %>
        <% if (nextCraving.minutesUntil !== null && nextCraving.minutesUntil > 0) { %>
          <span style="font-size:0.7rem;color:var(--text-muted);font-weight:400;">(<%= nextCraving.minutesUntil < 60 ? nextCraving.minutesUntil + ' min' : Math.floor(nextCraving.minutesUntil/60) + 'h ' + (nextCraving.minutesUntil%60) + 'm' %> me)</span>
        <% } %>
      </div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:0.6rem;color:var(--text-muted);"><%= nextCraving.confidence %>% sure</div>
      <div style="width:40px;height:4px;border-radius:2px;background:rgba(255,255,255,0.1);margin-top:2px;">
        <div style="width:<%= nextCraving.confidence %>%;height:100%;border-radius:2px;background:<%= nextCraving.confidence > 60 ? '#ff6b6b' : nextCraving.confidence > 30 ? '#ffd93d' : 'var(--olive-light)' %>;"></div>
      </div>
    </div>
  </div>
</div>
<% } %>

<!-- I Smoked Button -->
<div class="text-center mb-3 fade-in">
  <button type="button" class="btn-smoke" id="smokeBtn" onclick="openSmokeModal()">
    <i class="bi bi-fire"></i>
    <span>I Smoked</span>
  </button>
</div>

<!-- Smoke Modal (trigger/mood/note + date/time) -->
<div class="smoke-modal-overlay" id="smokeModal" style="display:none;" onclick="closeSmokeModalOutside(event)">
  <div class="smoke-modal">
    <div class="smoke-modal-header">
      <h6><i class="bi bi-fire"></i> Log Cigarette</h6>
      <button class="modal-close-btn" onclick="closeSmokeModal()">&times;</button>
    </div>
    <div class="smoke-modal-body">

      <!-- Date & Time Picker -->
      <div class="mb-3">
        <label class="form-label"><i class="bi bi-clock-history"></i> When did you smoke?</label>
        <div class="datetime-picker-wrap">
          <div class="dt-toggle-row">
            <button type="button" class="dt-toggle-btn dt-active" id="dtNowBtn" onclick="setDateTimeMode('now')">
              <i class="bi bi-clock"></i> Abhi
            </button>
            <button type="button" class="dt-toggle-btn" id="dtCustomBtn" onclick="setDateTimeMode('custom')">
              <i class="bi bi-calendar-event"></i> Custom Time
            </button>
          </div>
          <div id="dtCustomFields" style="display:none;" class="dt-custom-fields">
            <div class="d-flex gap-2">
              <div style="flex:1;">
                <label class="form-label" style="font-size:0.75rem;margin-bottom:2px;">Date</label>
                <input type="date" id="smokeDate" class="form-control input-dark" style="font-size:0.85rem;padding:8px 10px;">
              </div>
              <div style="flex:1;">
                <label class="form-label" style="font-size:0.75rem;margin-bottom:2px;">Time</label>
                <input type="time" id="smokeTime" class="form-control input-dark" style="font-size:0.85rem;padding:8px 10px;">
              </div>
            </div>
            <div class="dt-quick-row">
              <button type="button" class="dt-quick-chip" onclick="quickTimeOffset(5)">5 min pehle</button>
              <button type="button" class="dt-quick-chip" onclick="quickTimeOffset(15)">15 min</button>
              <button type="button" class="dt-quick-chip" onclick="quickTimeOffset(30)">30 min</button>
              <button type="button" class="dt-quick-chip" onclick="quickTimeOffset(60)">1 hour</button>
              <button type="button" class="dt-quick-chip" onclick="quickTimeOffset(120)">2 hours</button>
            </div>
          </div>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">What triggered it?</label>
        <div class="trigger-grid" id="triggerGrid">
          <button type="button" class="trigger-chip" data-val="stress"><i class="bi bi-lightning"></i> Stress</button>
          <button type="button" class="trigger-chip" data-val="boredom"><i class="bi bi-emoji-neutral"></i> Boredom</button>
          <button type="button" class="trigger-chip" data-val="social"><i class="bi bi-people"></i> Social</button>
          <button type="button" class="trigger-chip" data-val="craving"><i class="bi bi-fire"></i> Craving</button>
          <button type="button" class="trigger-chip" data-val="habit"><i class="bi bi-clock-history"></i> Habit</button>
          <button type="button" class="trigger-chip" data-val="after-meal"><i class="bi bi-cup-hot"></i> After Meal</button>
          <button type="button" class="trigger-chip" data-val="anxiety"><i class="bi bi-heartbreak"></i> Anxiety</button>
          <button type="button" class="trigger-chip" data-val="other"><i class="bi bi-three-dots"></i> Other</button>
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label">How are you feeling?</label>
        <div class="trigger-grid" id="moodGrid">
          <button type="button" class="mood-chip" data-val="stressed">😰 Stressed</button>
          <button type="button" class="mood-chip" data-val="anxious">😟 Anxious</button>
          <button type="button" class="mood-chip" data-val="bored">😑 Bored</button>
          <button type="button" class="mood-chip" data-val="relaxed">😌 Relaxed</button>
          <button type="button" class="mood-chip" data-val="angry">😠 Angry</button>
          <button type="button" class="mood-chip" data-val="sad">😢 Sad</button>
          <button type="button" class="mood-chip" data-val="happy">😊 Happy</button>
          <button type="button" class="mood-chip" data-val="neutral">😐 Neutral</button>
        </div>
      </div>
      <div class="mb-3">
        <input type="text" class="form-control input-dark" id="smokeNote" placeholder="Quick note (optional)" maxlength="100">
      </div>
    </div>
    <div class="smoke-modal-footer">
      <button class="btn btn-olive btn-ripple w-100" id="confirmSmokeBtn" onclick="confirmSmoke()">
        <span id="smokeBtnText"><i class="bi bi-check-lg"></i> Log It</span>
        <span id="smokeBtnLoader" style="display:none;">
          <span class="spinner-border spinner-border-sm"></span> Logging...
        </span>
      </button>
    </div>
  </div>
</div>

<!-- AI Feedback Panel (shows after logging) -->
<div class="glass-card ai-feedback-card mb-3 fade-in" id="aiFeedbackPanel" style="display:none;">
  <div class="d-flex align-items-start">
    <div class="ai-icon-wrap"><i class="bi bi-robot"></i></div>
    <div style="flex:1;min-width:0;">
      <div class="d-flex align-items-center gap-2 mb-1">
        <h6 class="mb-0" style="color:#8ab4f8;font-size:0.8rem;font-weight:600;">AI Feedback</h6>
        <span class="ai-badge" style="margin-bottom:0;"><i class="bi bi-stars"></i> Live</span>
      </div>
      <div class="ai-text" id="aiFeedbackText"></div>
    </div>
  </div>
</div>

<!-- ═══ MIDDLE: Quick Stats Row ═══ -->
<div class="row g-2 mb-3">
  <div class="col-3 fade-in">
    <div class="stat-card mini-stat">
      <div class="mini-val"><%= streak.currentStreak %></div>
      <div class="mini-lbl">🔥 Streak</div>
    </div>
  </div>
  <div class="col-3 fade-in">
    <div class="stat-card mini-stat">
      <div class="mini-val" id="cravingTimer">
        <% if (streak.lastMinutesAgo !== null) { %>
          <% const hrs = Math.floor(streak.lastMinutesAgo / 60); const mins = streak.lastMinutesAgo % 60; %>
          <%= hrs > 0 ? hrs + 'h ' : '' %><%= mins %>m
        <% } else { %>--<% } %>
      </div>
      <div class="mini-lbl">⏱️ Gap</div>
    </div>
  </div>
  <div class="col-3 fade-in">
    <div class="stat-card mini-stat">
      <div class="mini-val">
        <% const pkH = peakHour % 12 || 12; const pkSuffix = peakHour >= 12 ? 'PM' : 'AM'; %>
        <%= pkH %><small><%= pkSuffix %></small>
      </div>
      <div class="mini-lbl">⏰ Peak</div>
    </div>
  </div>
  <div class="col-3 fade-in">
    <div class="stat-card mini-stat">
      <div class="mini-val">
        <% if (trend === 'improving') { %>
          <span style="color:var(--accent-green);font-size:0.75rem;">📉 Down</span>
        <% } else if (trend === 'worsening') { %>
          <span style="color:var(--accent-red);font-size:0.75rem;">📈 Up</span>
        <% } else { %>
          <span style="color:var(--accent-yellow);font-size:0.75rem;">➡️ Same</span>
        <% } %>
      </div>
      <div class="mini-lbl">Trend</div>
    </div>
  </div>
</div>

<!-- Today's Timeline -->
<% if (timeline && timeline.length > 0) { %>
<div class="glass-card mb-3 fade-in">
  <h6 class="card-title"><i class="bi bi-clock-history"></i> Today's Timeline</h6>
  <div class="timeline-wrap" id="timelineWrap">
    <% timeline.forEach(function(entry, idx) { %>
      <div class="timeline-entry">
        <div class="timeline-dot"></div>
        <div class="timeline-content">
          <span class="timeline-time"><%= entry.time %></span>
          <% if (entry.trigger) { %><span class="timeline-tag trigger-tag"><%= entry.trigger %></span><% } %>
          <% if (entry.mood) { %><span class="timeline-tag mood-tag"><%= entry.mood %></span><% } %>
        </div>
      </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- ═══ BOTTOM: Money & Life Lost ═══ -->
<div class="glass-card mb-3 fade-in" style="padding:12px 16px;">
  <h6 class="card-title mb-2"><i class="bi bi-fire"></i> 🔥 Har Cigarette Ki Keemat</h6>
  <!-- Per cigarette loss -->
  <div class="text-center mb-3" style="padding:8px;border-radius:10px;background:rgba(255,107,107,0.08);border:1px solid rgba(255,107,107,0.15);">
    <div style="font-size:1rem;font-weight:700;color:#ff6b6b;">₹<%= settings.costPerCigarette %> + 11 min zindagi</div>
    <div style="font-size:0.65rem;color:var(--text-muted);">har ek cigarette me itna jaata hai</div>
  </div>
  <div class="d-flex justify-content-between text-center">
    <div>
      <div style="font-size:1.1rem;font-weight:700;color:var(--olive-light);">₹<%= financials.monthlyCost %></div>
      <div style="font-size:0.65rem;color:var(--text-muted);">Month</div>
    </div>
    <div>
      <div style="font-size:1.1rem;font-weight:700;color:#ffd93d;">₹<%= financials.yearlyCost %></div>
      <div style="font-size:0.65rem;color:var(--text-muted);">Year</div>
    </div>
    <div>
      <div style="font-size:1.1rem;font-weight:700;color:#ff6b6b;">₹<%= financials.lifetimeCost %></div>
      <div style="font-size:0.65rem;color:var(--text-muted);">Lifetime</div>
    </div>
  </div>
  <% if (financials.lifetimeCigarettes > 0) { %>
  <div class="text-center mt-2" style="padding:6px;border-radius:8px;background:rgba(255,217,61,0.08);">
    <div style="font-size:0.8rem;font-weight:600;color:#ffd93d;">⏳ <%= Math.round(financials.lifetimeCigarettes * 11 / 60) %> hours of life lost</div>
    <div style="font-size:0.6rem;color:var(--text-muted);">
      <%= financials.lifetimeCigarettes %> cigarettes × 11 min (WHO estimate)
    </div>
  </div>
  <% } %>
</div>

<!-- Behavior Insights Pills -->
<% if (risk.flags.length > 0) { %>
<div class="glass-card mb-3 fade-in">
  <h6 class="card-title"><i class="bi bi-activity"></i> Aaj Ka Haal</h6>
  <div style="display:flex;flex-direction:column;gap:8px;">
    <% risk.flags.forEach(function(f) { %>
    <%
      // Plain Hindi text map by category
      var pillEmoji = f.severity === 'danger' ? '🔴' : f.severity === 'warning' ? '🟡' : '🟢';
      var pillBg = f.severity === 'danger' ? 'rgba(255,70,70,0.1)' : f.severity === 'warning' ? 'rgba(255,217,61,0.1)' : 'rgba(107,255,107,0.08)';
      var pillBorder = f.severity === 'danger' ? 'rgba(255,70,70,0.25)' : f.severity === 'warning' ? 'rgba(255,217,61,0.25)' : 'rgba(107,255,107,0.2)';
      var pillColor = f.severity === 'danger' ? '#ff6b6b' : f.severity === 'warning' ? '#ffd93d' : 'var(--accent-green)';
      var categoryLabel = f.category === 'limit' ? '🎯 Limit' : f.category === 'gap' ? '⏱️ Gap' : f.category === 'trend' ? '📈 Trend' : f.category === 'pattern' ? '🕐 Peak Time' : f.category === 'trigger' ? '⚡ Trigger' : '💡 Behaviour';
      var trendLabel = f.trend === 'worsening' ? '↑ Badh raha' : f.trend === 'improving' ? '↓ Sudhar raha' : '→ Same hai';
    %>
    <div style="background:<%= pillBg %>;border:1px solid <%= pillBorder %>;border-radius:10px;padding:10px 12px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:2px;">
        <span style="font-size:0.65rem;font-weight:700;color:<%= pillColor %>;text-transform:uppercase;letter-spacing:0.5px;"><%= categoryLabel %></span>
        <span style="font-size:0.6rem;color:var(--text-muted);"><%= trendLabel %></span>
      </div>
      <div style="font-size:0.8rem;color:var(--text-primary);line-height:1.4;"><%= pillEmoji %> <%= f.text %></div>
    </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- ═══ Trigger × Time Patterns ═══ -->
<% if (triggerTimePatterns && triggerTimePatterns.length > 0) { %>
<div class="glass-card mb-3 fade-in" style="padding:12px 16px;">
  <h6 class="card-title" style="font-size:0.8rem;"><i class="bi bi-lightning-charge"></i> Trigger × Time Patterns</h6>
  <% triggerTimePatterns.forEach(function(ttp) { %>
  <div class="d-flex align-items-center justify-content-between mb-1" style="font-size:0.75rem;">
    <span style="color:var(--olive-light);font-weight:600;"><%= ttp.combo %></span>
    <div class="d-flex align-items-center gap-2">
      <div style="width:60px;height:6px;border-radius:3px;background:rgba(255,255,255,0.08);overflow:hidden;">
        <div style="height:100%;width:<%= ttp.percentage %>%;background:<%= ttp.percentage > 40 ? '#ff6b6b' : 'var(--olive-light)' %>;border-radius:3px;"></div>
      </div>
      <span style="color:var(--text-muted);font-size:0.65rem;min-width:28px;text-align:right;"><%= ttp.percentage %>%</span>
    </div>
  </div>
  <% }); %>
  <div style="font-size:0.6rem;color:var(--text-muted);margin-top:6px;">⚠️ Ye sabse frequent trigger+time combos hain — in situations me alert raho</div>
</div>
<% } %>

<!-- ═══ Next Craving Prediction ═══ -->
<% if (nextCraving && nextCraving.confidence > 0) { %>
<div class="glass-card mb-3 fade-in" style="padding:12px 16px;">
  <div class="d-flex align-items-center gap-2 mb-1">
    <span style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;">⚡ Craving Prediction</span>
    <span style="font-size:0.65rem;padding:2px 8px;border-radius:20px;background:rgba(107,143,113,0.15);color:var(--olive-light);"><%= nextCraving.confidence %>% confident</span>
  </div>
  <div style="font-size:1rem;font-weight:700;color:var(--olive-light);">
    <% if (nextCraving.minutesUntil !== null && nextCraving.minutesUntil > 0) { %>
      <% const nhrs = Math.floor(nextCraving.minutesUntil / 60); const nmins = nextCraving.minutesUntil % 60; %>
      <i class="bi bi-clock-history"></i>
      Next craving in ~<%= nhrs > 0 ? nhrs + 'h ' : '' %><%= nmins %>m
    <% } else { %>
      <i class="bi bi-exclamation-circle"></i> High risk window now
    <% } %>
  </div>
  <div style="font-size:0.7rem;color:var(--text-muted);margin-top:2px;">
    <% const nHour = nextCraving.nextLikelyHour; const nAmPm = nHour >= 12 ? (nHour === 12 ? '12PM' : (nHour-12) + 'PM') : (nHour === 0 ? '12AM' : nHour + 'AM'); %>
    Based on your pattern — peak at <%= nAmPm %>
  </div>
</div>
<% } %>

<!-- ═══ Achievements ═══ -->
<% if (achievements && (achievements.timeMilestones.length > 0 || achievements.streakMilestones.length > 0)) { %>
<div class="glass-card mb-3 fade-in">
  <h6 class="card-title"><i class="bi bi-trophy"></i> Achievements</h6>
  <div class="achievements-grid" id="achievementsGrid">
    <% achievements.timeMilestones.forEach(function(m) { %>
      <div class="achievement-badge <%= m.unlocked ? 'badge-unlocked' : 'badge-locked' %>" title="<%= m.label %>">
        <span class="ach-icon"><%= m.icon %></span>
        <span class="ach-label"><%= m.label %></span>
      </div>
    <% }); %>
    <% achievements.streakMilestones.forEach(function(m) { %>
      <div class="achievement-badge <%= m.unlocked ? 'badge-unlocked' : 'badge-locked' %>" title="<%= m.label %>">
        <span class="ach-icon"><%= m.icon %></span>
        <span class="ach-label"><%= m.label %></span>
      </div>
    <% }); %>
  </div>
  <% if (achievements.gapRecord && achievements.gapRecord > 0) { %>
  <div style="font-size:0.7rem;color:var(--text-muted);text-align:center;margin-top:8px;">
    🏅 Best gap: <%= Math.floor(achievements.gapRecord / 60) > 0 ? Math.floor(achievements.gapRecord / 60) + 'h ' : '' %><%= achievements.gapRecord % 60 %>m between cigarettes
  </div>
  <% } %>
</div>
<% } %>

<!-- ═══ Social Proof Nudge ═══ -->
<div class="glass-card mb-3 fade-in social-proof-card" id="socialProofCard">
  <div class="d-flex align-items-start gap-2">
    <span style="font-size:1.2rem;">💡</span>
    <div>
      <div style="font-size:0.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;">Did you know?</div>
      <div id="socialProofText" class="social-proof-text">Loading...</div>
    </div>
  </div>
</div>

<!-- AI Advice (loaded client-side via Puter.js) -->
<div class="glass-card ai-card mb-3 fade-in">
  <h6 class="card-title"><i class="bi bi-robot"></i> AI Advice</h6>
  <div class="ai-badge"><i class="bi bi-stars"></i> GPT-4.1 Powered</div>
  <div id="dashboardAILoader" class="ai-loader-wrap">
    <div class="spinner-border spinner-border-sm"></div>
    <small>Analyzing your patterns...</small>
  </div>
  <div id="dashboardAIText" class="ai-text-glow" style="display:none;">
    <div class="ai-text"></div>
  </div>
</div>

<script>
  window.__dailyGoal = <%- JSON.stringify(settings.dailyGoal) %>;
  window.__lastMinutesAgo = <%- streak.lastMinutesAgo !== null ? JSON.stringify(streak.lastMinutesAgo) : 'null' %>;
  window.__dashboardData = <%- JSON.stringify({
    todayCount: todayCount,
    weeklyAvg: weeklyAvg,
    peakHour: peakHour,
    trend: risk.trend,
    avgGap: avgGap,
    riskScore: risk.score,
    riskLevel: risk.riskLevel,
    flags: risk.flags.map(function(f) { return f.text; }),
    flagsDetailed: risk.flags,
    scoreBreakdown: risk.scoreBreakdown,
    consecutiveBreach: risk.consecutiveBreach,
    triggerBreakdown: risk.triggerBreakdown,
    gapTrend: risk.gapTrend,
    streak: { currentStreak: streak.currentStreak, todayCount: streak.todayCount, yesterdayCount: streak.yesterdayCount },
    dailyGoal: settings.dailyGoal,
    costPerCigarette: settings.costPerCigarette,
    totalLifetime: financials.lifetimeCigarettes,
    lastMinutesAgo: streak.lastMinutesAgo,
    nextCraving: nextCraving,
    triggerTimePatterns: triggerTimePatterns,
    achievements: achievements
  }) %>;
</script>

</div><!-- /page-content -->

<%- include('partials/footer') %>
