<%- include('layout') %>

<!-- Floating Smoke Particles -->
<div class="smoke-particles">
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
  <div class="smoke-particle"></div><div class="smoke-particle"></div>
</div>

<div class="page-content">
<h5 class="text-center mb-3 fade-in" style="color:var(--olive-light);"><i class="bi bi-gear"></i> Settings</h5>

<form action="/settings" method="POST" class="fade-in">
  <div class="glass-card mb-3">
    <div class="mb-3">
      <label class="form-label">Cost Per Cigarette (₹)</label>
      <input type="number" step="0.5" name="costPerCigarette" class="form-control input-dark" placeholder="e.g. 15" value="<%= settings ? settings.costPerCigarette : '' %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label">Daily Goal (max cigarettes)</label>
      <input type="number" name="dailyGoal" class="form-control input-dark" placeholder="e.g. 5" value="<%= settings ? settings.dailyGoal : 5 %>">
    </div>
    <button type="submit" class="btn btn-olive btn-ripple w-100"><i class="bi bi-check-lg"></i> Save Settings</button>
  </div>
</form>

</div><!-- /page-content -->

<%- include('partials/footer') %>
